{
  "name": "robot-lifecycle-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @robot/web",
    "build": "npm run build -w @robot/web",
    "start": "npm run start -w @robot/web",
    "lint": "npm run lint -w @robot/web",
    "typecheck": "npm run typecheck -w @robot/web",
    "db:start": "prisma dev --name rooboot --detach",
    "db:stop": "prisma dev stop rooboot",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next-auth": "^4.24.14",
    "pg": "^8.22.0"
  }
}
